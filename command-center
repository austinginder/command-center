#!/usr/bin/env php
<?php
/**
 * Command Center CLI - search conversation history across AI coding tools.
 *
 * Usage:
 *   command-center <query>                    Search conversations (default)
 *   command-center search <query> [options]   Explicit search
 *   command-center reindex                    Rebuild the FTS5 index
 *   command-center status                     Index health stats
 *   command-center sessions [-p project]      List sessions
 *   command-center projects                   List projects
 *   command-center open <session-id>          Open in browser
 *   command-center version                    Show installed version
 *   command-center update [--check]           Update to the latest release
 *
 * Options:
 *   -p, --project <name|path>      Filter by project
 *   -a, --agent <id|name>          Filter by agent (claude, command-code, t3-code, etc.)
 *   -n, --limit <N>                Max results (default: 20)
 *   -j, --json                     JSON output
 *       --no-color                 Disable ANSI colors
 *       --no-update                Skip incremental index update
 *   -h, --help                     Show help
 */

if ( php_sapi_name() !== 'cli' ) {
	http_response_code( 403 );
	exit( 'CLI only.' );
}

define( 'BASE_DIR', __DIR__ );
define( 'DATA_DIR', __DIR__ . '/data' );

require BASE_DIR . '/app/Helpers.php';
require BASE_DIR . '/app/AmpSessions.php';
require BASE_DIR . '/app/ClaudeSessions.php';
require BASE_DIR . '/app/CommandCodeSessions.php';
require BASE_DIR . '/app/T3CodeSessions.php';
require BASE_DIR . '/app/OpenCodeSessions.php';
require BASE_DIR . '/app/KimiSessions.php';
require BASE_DIR . '/app/AntigravitySessions.php';
require BASE_DIR . '/app/GeminiSessions.php';
require BASE_DIR . '/app/GrokSessions.php';
require BASE_DIR . '/app/SessionRegistry.php';
require BASE_DIR . '/app/Retention.php';
require BASE_DIR . '/app/SearchIndex.php';
require BASE_DIR . '/app/FlowExtractor.php';

// ─── Argument Parsing ────────────────────────────────────────

$args      = array_slice( $argv, 1 );
$flags     = [];
$positional = [];

for ( $i = 0; $i < count( $args ); $i++ ) {
	$arg = $args[ $i ];

	if ( $arg === '--' ) {
		// Everything after -- is positional.
		$positional = array_merge( $positional, array_slice( $args, $i + 1 ) );
		break;
	}

	if ( in_array( $arg, [ '-p', '--project' ], true ) ) {
		$flags['project'] = $args[ ++$i ] ?? '';
	} elseif ( in_array( $arg, [ '-n', '--limit' ], true ) ) {
		$flags['limit'] = (int) ( $args[ ++$i ] ?? 20 );
	} elseif ( in_array( $arg, [ '-s', '--session' ], true ) ) {
		$flags['session'] = $args[ ++$i ] ?? '';
	} elseif ( $arg === '--full' ) {
		$flags['full'] = true;
	} elseif ( $arg === '--forensic' ) {
		$flags['forensic'] = true;
	} elseif ( $arg === '--dump-images' ) {
		$flags['dump-images'] = $args[ ++$i ] ?? '';
	} elseif ( $arg === '--editor' ) {
		$flags['editor'] = true;
	} elseif ( $arg === '--images-dir' ) {
		$flags['images-dir'] = $args[ ++$i ] ?? '';
	} elseif ( in_array( $arg, [ '-a', '--agent' ], true ) ) {
		$flags['agent'] = $args[ ++$i ] ?? '';
	} elseif ( str_starts_with( $arg, '--agent=' ) ) {
		$flags['agent'] = substr( $arg, strlen( '--agent=' ) );
	} elseif ( str_starts_with( $arg, '-a=' ) ) {
		$flags['agent'] = substr( $arg, 3 );
	} elseif ( in_array( $arg, [ '-j', '--json' ], true ) ) {
		$flags['json'] = true;
	} elseif ( $arg === '--no-color' ) {
		$flags['no-color'] = true;
	} elseif ( $arg === '--no-update' ) {
		$flags['no-update'] = true;
	} elseif ( $arg === '--check' ) {
		$flags['check'] = true;
	} elseif ( in_array( $arg, [ '-v', '--version' ], true ) ) {
		$flags['version'] = true;
	} elseif ( in_array( $arg, [ '-h', '--help' ], true ) ) {
		$flags['help'] = true;
	} else {
		$positional[] = $arg;
	}
}

$useJson  = ! empty( $flags['json'] );
$useColor = ! $useJson && detectColor( $flags );
$limit    = $flags['limit'] ?? 20;

// ─── Subcommand Dispatch ─────────────────────────────────────

$subcommands = [ 'search', 'reindex', 'status', 'sessions', 'projects', 'open', 'flow', 'version', 'update', 'help' ];
$subcommand  = 'search';
$queryParts  = $positional;

if ( ! empty( $flags['help'] ) || ( isset( $positional[0] ) && $positional[0] === 'help' ) ) {
	showHelp();
	exit( 0 );
}

if ( ! empty( $flags['version'] ) ) {
	cmdVersion( $useJson );
}

if ( ! empty( $positional ) && in_array( $positional[0], $subcommands, true ) ) {
	$subcommand = array_shift( $queryParts );
}

// If no subcommand and no positional args, show help.
if ( $subcommand === 'search' && empty( $queryParts ) ) {
	showHelp();
	exit( 2 );
}

$agent = resolveAgent( $flags['agent'] ?? null );

try {
	match ( $subcommand ) {
		'search'   => cmdSearch( implode( ' ', $queryParts ), $flags, $limit, $useJson, $useColor, $agent ),
		'reindex'  => cmdReindex( $useJson ),
		'status'   => cmdStatus( $useJson ),
		'sessions' => cmdSessions( $flags, $useJson, $useColor, $agent ),
		'projects' => cmdProjects( $useJson, $useColor, $agent ),
		'open'     => cmdOpen( $queryParts[0] ?? '' ),
		'flow'     => cmdFlow( $queryParts[0] ?? '', $flags, $useJson, $useColor ),
		'version'  => cmdVersion( $useJson ),
		'update'   => cmdUpdate( $flags, $useJson, $useColor ),
		default    => cmdSearch( implode( ' ', $queryParts ), $flags, $limit, $useJson, $useColor, $agent ),
	};
} catch ( \Exception $e ) {
	fwrite( STDERR, "Error: {$e->getMessage()}\n" );
	exit( 3 );
}

// ─── Commands ────────────────────────────────────────────────

function cmdSearch( string $query, array $flags, int $limit, bool $useJson, bool $useColor, ?string $source = null ): void {
	if ( mb_strlen( $query ) < 3 ) {
		fwrite( STDERR, "Query must be at least 3 characters.\n" );
		exit( 2 );
	}

	$project = resolveProject( $flags['project'] ?? null );

	if ( ! empty( $flags['no-update'] ) ) {
		// Skip incremental update - query the index directly.
		$results = SearchIndex::search( $query, $project, $source, $limit );
	} else {
		$results = SessionRegistry::deepSearch( $query, $project, $source );
	}

	// Apply limit (deepSearch returns up to 50).
	$results = array_slice( $results, 0, $limit );

	if ( empty( $results ) ) {
		if ( $useJson ) {
			echo "[]\n";
		} else {
			fwrite( STDERR, "No results found.\n" );
		}
		exit( 1 );
	}

	if ( $useJson ) {
		$clean = array_map( function ( $r ) {
			$r['snippet'] = stripSnippetHtml( $r['snippet'] ?? '' );
			return $r;
		}, $results );
		echo json_encode( $clean, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES ) . "\n";
		exit( 0 );
	}

	// Human-readable output.
	foreach ( $results as $r ) {
		$project  = dim( str_pad( $r['projectName'] ?: '-', 20 ), $useColor );
		$timeAgo  = dim( str_pad( Helpers::timeAgo( $r['timestamp_s'] ), 8 ), $useColor );
		$display  = bold( $r['display'] ?: $r['id'], $useColor );
		$snippet  = formatSnippet( $r['snippet'] ?? '', $useColor );

		echo "  {$project} {$timeAgo} {$display}\n";
		if ( $snippet ) {
			echo "  {$snippet}\n";
		}
		echo "\n";
	}

	$count = count( $results );
	echo dim( "{$count} result" . ( $count !== 1 ? 's' : '' ) . " found.\n", $useColor );
	exit( 0 );
}

function cmdReindex( bool $useJson ): void {
	$sessions = SessionRegistry::listSessions();

	if ( ! $useJson ) {
		fwrite( STDERR, "Rebuilding index for " . count( $sessions ) . " sessions...\n" );
	}

	$result = SearchIndex::rebuild( $sessions );

	if ( $useJson ) {
		echo json_encode( $result, JSON_PRETTY_PRINT ) . "\n";
	} else {
		echo "Indexed {$result['indexed']} sessions in {$result['elapsed_ms']}ms\n";
		$status = SearchIndex::status();
		echo "DB size: " . Helpers::formatBytes( $status['db_size_bytes'] ) . "\n";
	}
	exit( 0 );
}

function cmdStatus( bool $useJson ): void {
	$status = SearchIndex::status();

	if ( $useJson ) {
		echo json_encode( $status, JSON_PRETTY_PRINT ) . "\n";
		exit( 0 );
	}

	echo "Index status\n";
	echo "  Sessions indexed: {$status['indexed']}\n";
	echo "  Database size:    " . Helpers::formatBytes( $status['db_size_bytes'] ) . "\n";
	echo "  Last indexed:     " . ( $status['last_indexed'] ? Helpers::timeAgo( $status['last_indexed'] ) : 'never' ) . "\n";
	exit( 0 );
}

function cmdSessions( array $flags, bool $useJson, bool $useColor, ?string $source = null ): void {
	$project  = resolveProject( $flags['project'] ?? null );
	$sessions = SessionRegistry::listSessions( $project, $source );

	if ( $useJson ) {
		echo json_encode( $sessions, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES ) . "\n";
		exit( 0 );
	}

	if ( empty( $sessions ) ) {
		echo "No sessions found.\n";
		exit( 1 );
	}

	foreach ( $sessions as $s ) {
		$project = dim( str_pad( $s['projectName'] ?: '-', 20 ), $useColor );
		$timeAgo = dim( str_pad( Helpers::timeAgo( $s['timestamp_s'] ), 8 ), $useColor );
		$display = $s['display'] ?: $s['id'];
		$size    = dim( Helpers::formatBytes( $s['size'] ), $useColor );
		echo "  {$project} {$timeAgo} {$display}  {$size}\n";
	}

	echo "\n" . dim( count( $sessions ) . " sessions.\n", $useColor );
	exit( 0 );
}

function cmdProjects( bool $useJson, bool $useColor, ?string $source = null ): void {
	$projects = SessionRegistry::listProjects( $source );

	if ( $useJson ) {
		echo json_encode( $projects, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES ) . "\n";
		exit( 0 );
	}

	if ( empty( $projects ) ) {
		echo "No projects found.\n";
		exit( 1 );
	}

	foreach ( $projects as $p ) {
		$name     = bold( str_pad( $p['name'], 30 ), $useColor );
		$count    = dim( str_pad( $p['sessions'] . ' sessions', 14 ), $useColor );
		$timeAgo  = dim( Helpers::timeAgo( intval( $p['latest'] / 1000 ) ), $useColor );
		echo "  {$name} {$count} {$timeAgo}\n";
	}

	echo "\n" . dim( count( $projects ) . " projects.\n", $useColor );
	exit( 0 );
}

function cmdOpen( string $sessionId ): void {
	if ( empty( $sessionId ) ) {
		fwrite( STDERR, "Usage: command-center open <session-id>\n" );
		exit( 2 );
	}

	$url = 'http://command-center.localhost/sessions/' . urlencode( $sessionId );
	exec( 'open ' . escapeshellarg( $url ) );
	echo "Opened {$sessionId}\n";
	exit( 0 );
}

// ─── Version & Update ────────────────────────────────────────

function localManifest(): array {
	$file = BASE_DIR . '/manifest.json';
	if ( ! is_readable( $file ) ) {
		fwrite( STDERR, "Missing manifest.json - is this a complete install?\n" );
		exit( 3 );
	}
	$manifest = json_decode( file_get_contents( $file ), true );
	if ( ! is_array( $manifest ) || empty( $manifest['version'] ) ) {
		fwrite( STDERR, "Invalid manifest.json.\n" );
		exit( 3 );
	}
	return $manifest;
}

function remoteManifest(): ?array {
	$context = stream_context_create( [
		'http' => [
			'timeout' => 15,
			'header'  => "Accept: application/json\r\nUser-Agent: command-center-cli\r\n",
		],
	] );
	$body = @file_get_contents( 'https://raw.githubusercontent.com/austinginder/command-center/main/manifest.json', false, $context );
	if ( $body === false ) {
		return null;
	}
	$manifest = json_decode( $body, true );
	if ( ! is_array( $manifest ) || empty( $manifest['version'] ) ) {
		return null;
	}
	return $manifest;
}

function cmdVersion( bool $useJson ): void {
	$manifest = localManifest();
	if ( $useJson ) {
		echo json_encode( $manifest, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES ) . "\n";
	} else {
		echo "Command Center v{$manifest['version']}\n";
	}
	exit( 0 );
}

function cmdUpdate( array $flags, bool $useJson, bool $useColor ): void {
	$local  = localManifest();
	$remote = remoteManifest();

	if ( $remote === null ) {
		fwrite( STDERR, "Could not reach GitHub to check for updates.\n" );
		exit( 3 );
	}

	$current = $local['version'];
	$latest  = $remote['version'];

	if ( ! version_compare( $latest, $current, '>' ) ) {
		if ( $useJson ) {
			echo json_encode( [ 'current' => $current, 'latest' => $latest, 'update_available' => false ], JSON_PRETTY_PRINT ) . "\n";
		} else {
			echo "Already up to date (v{$current}).\n";
		}
		exit( 0 );
	}

	if ( ! empty( $remote['requires_php'] ) && version_compare( PHP_VERSION, $remote['requires_php'], '<' ) ) {
		fwrite( STDERR, "v{$latest} requires PHP {$remote['requires_php']}+ (you have " . PHP_VERSION . ").\n" );
		exit( 3 );
	}

	if ( ! empty( $flags['check'] ) ) {
		if ( $useJson ) {
			echo json_encode( [ 'current' => $current, 'latest' => $latest, 'update_available' => true ], JSON_PRETTY_PRINT ) . "\n";
		} else {
			echo "Update available: v{$current} → v{$latest}\n";
			echo "Run " . bold( 'command-center update', $useColor ) . " to install.\n";
		}
		exit( 0 );
	}

	echo "Updating v{$current} → v{$latest}...\n";

	if ( is_dir( BASE_DIR . '/.git' ) ) {
		updateViaGit();
	} else {
		updateViaZip( $remote );
	}

	$new = json_decode( file_get_contents( BASE_DIR . '/manifest.json' ), true );
	echo "Updated to v" . ( $new['version'] ?? $latest ) . ".\n";
	exit( 0 );
}

function updateViaGit(): void {
	exec( 'git -C ' . escapeshellarg( BASE_DIR ) . ' status --porcelain 2>&1', $dirty, $code );
	if ( $code !== 0 ) {
		fwrite( STDERR, "git status failed - update manually with git pull.\n" );
		exit( 3 );
	}
	if ( ! empty( $dirty ) ) {
		fwrite( STDERR, "Working tree has local changes - commit or stash them, then run update again.\n" );
		exit( 3 );
	}
	exec( 'git -C ' . escapeshellarg( BASE_DIR ) . ' pull --ff-only origin main 2>&1', $out, $code );
	if ( $code !== 0 ) {
		fwrite( STDERR, "git pull failed:\n" . implode( "\n", $out ) . "\n" );
		exit( 3 );
	}
}

function updateViaZip( array $remote ): void {
	if ( empty( $remote['download_url'] ) ) {
		fwrite( STDERR, "Remote manifest has no download_url.\n" );
		exit( 3 );
	}
	if ( ! class_exists( 'ZipArchive' ) ) {
		fwrite( STDERR, "PHP zip extension is required for non-git updates.\n" );
		exit( 3 );
	}

	$tmpZip = tempnam( sys_get_temp_dir(), 'cc-update-' ) . '.zip';
	$context = stream_context_create( [ 'http' => [ 'timeout' => 60, 'header' => "User-Agent: command-center-cli\r\n", 'follow_location' => 1 ] ] );
	$data = @file_get_contents( $remote['download_url'], false, $context );
	if ( $data === false || file_put_contents( $tmpZip, $data ) === false ) {
		fwrite( STDERR, "Download failed: {$remote['download_url']}\n" );
		exit( 3 );
	}

	$tmpDir = sys_get_temp_dir() . '/cc-update-' . getmypid();
	$zip    = new ZipArchive();
	if ( $zip->open( $tmpZip ) !== true || ! $zip->extractTo( $tmpDir ) ) {
		fwrite( STDERR, "Could not extract update archive.\n" );
		exit( 3 );
	}
	$zip->close();
	unlink( $tmpZip );

	// GitHub tag archives wrap everything in a single top-level directory.
	$entries = array_values( array_diff( scandir( $tmpDir ), [ '.', '..' ] ) );
	$root    = ( count( $entries ) === 1 && is_dir( "{$tmpDir}/{$entries[0]}" ) ) ? "{$tmpDir}/{$entries[0]}" : $tmpDir;

	copyTree( $root, BASE_DIR );

	exec( 'rm -rf ' . escapeshellarg( $tmpDir ) );
}

function copyTree( string $src, string $dest ): void {
	// Never touch local data (search index, caches) or version control.
	$skip = [ 'data', '.git' ];
	foreach ( array_diff( scandir( $src ), [ '.', '..' ] ) as $entry ) {
		if ( in_array( $entry, $skip, true ) ) {
			continue;
		}
		$from = "{$src}/{$entry}";
		$to   = "{$dest}/{$entry}";
		if ( is_dir( $from ) ) {
			if ( ! is_dir( $to ) ) {
				mkdir( $to, 0755, true );
			}
			copyTree( $from, $to );
		} else {
			copy( $from, $to );
			// Preserve executability (the CLI script itself).
			if ( is_executable( $from ) ) {
				chmod( $to, 0755 );
			}
		}
	}
}

// ─── Flow ────────────────────────────────────────────────────

/**
 * command-center flow [project] [options]
 *   --session <id>   Deep-dive one session instead of the whole project
 *   --full           Forensic play-by-play (interleaved user turns + agent trace)
 *   --forensic       Verbatim user turns only
 *   --editor         Editor brief: one JSON bundle an agent uses to WRITE the recap
 *                    (manifest + spine + tacks + genesis interleaved flow + decoded
 *                    landmark screenshots). --images-dir <dir> sets where images land.
 *   --json           Structured payload (the "browse the build" ingest format)
 * With no flags: the cliffnotes - arc, steering, course-corrections, model + cost.
 */
function cmdFlow( string $project, array $flags, bool $useJson, bool $useColor ): void {
	$sessionId = $flags['session'] ?? null;

	// Single-session deep dive.
	if ( $sessionId ) {
		$file = FlowExtractor::resolveSessionFile( $sessionId ) ?? ClaudeSessions::findSessionFileById( $sessionId );
		if ( ! $file ) {
			fwrite( STDERR, "Session not found: {$sessionId}\n" );
			exit( 2 );
		}
		// Decode embedded screenshots for the editor/captioning pass.
		if ( ! empty( $flags['dump-images'] ) ) {
			$manifest = FlowExtractor::decodeImages( $file, $flags['dump-images'] );
			if ( $useJson ) {
				echo json_encode( $manifest, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES ) . "\n";
			} else {
				echo count( $manifest ) . " image(s) written to {$flags['dump-images']}\n";
				foreach ( $manifest as $m ) {
					printf( "  %-14s %5dKB  %s\n", $m['file'], intdiv( $m['bytes'], 1024 ), preg_replace( '/\s+/', ' ', $m['paired'] ) );
				}
			}
			exit( 0 );
		}
		$parsed = FlowExtractor::parseSession( $file );
		if ( $useJson ) {
			echo json_encode( flowSessionPayload( $sessionId, $parsed ), JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES ) . "\n";
			exit( 0 );
		}
		renderSessionFlow( $sessionId, $parsed, $useColor );
		exit( 0 );
	}

	// Whole-project flow.
	if ( $project === '' ) {
		fwrite( STDERR, "Usage: command-center flow <project> [--full|--forensic|--json]\n       command-center flow --session <id>\n" );
		exit( 2 );
	}
	$dir = FlowExtractor::resolveProjectDir( $project );
	if ( ! $dir ) {
		fwrite( STDERR, "No project matching: {$project}\n" );
		exit( 2 );
	}

	// Editor brief - one bundle with everything an agent needs to WRITE the recap
	// (manifest + spine + tacks + genesis interleaved flow + decoded landmark images).
	if ( ! empty( $flags['editor'] ) ) {
		$imagesDir = $flags['images-dir'] ?? ( sys_get_temp_dir() . '/rutter-landmarks/' . preg_replace( '/[^a-z0-9]+/i', '-', $project ) );
		$brief     = FlowExtractor::editorBrief( $dir, $imagesDir );
		if ( ! $brief ) {
			fwrite( STDERR, "No sessions with user turns found in {$dir}\n" );
			exit( 1 );
		}
		echo json_encode( $brief, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES ) . "\n";
		exit( 0 );
	}

	$flow = FlowExtractor::projectFlow( $dir );
	if ( $flow['totals']['sessions'] === 0 ) {
		fwrite( STDERR, "No sessions with user turns found in {$dir}\n" );
		exit( 1 );
	}

	if ( $useJson ) {
		echo json_encode( $flow, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES ) . "\n";
		exit( 0 );
	}
	if ( ! empty( $flags['full'] ) || ! empty( $flags['forensic'] ) ) {
		renderProjectForensic( $flow, ! empty( $flags['full'] ), $useColor );
		exit( 0 );
	}
	renderCliffnotes( $flow, $useColor );
	exit( 0 );
}

function flowSessionPayload( string $id, array $parsed ): array {
	$seq = [];
	foreach ( $parsed['turns'] as $t ) {
		if ( $t['role'] === 'user' ) {
			$seq[] = [ 'role' => 'user', 'kind' => $t['kind'], 'ts' => $t['ts'], 'text' => $t['text'] ];
		} else {
			$counts = [];
			foreach ( $t['tools'] as [ $name, $label ] ) {
				$counts[ $name ] = ( $counts[ $name ] ?? 0 ) + 1;
			}
			$seq[] = [ 'role' => 'agent', 'tools' => $counts, 'calls' => count( $t['tools'] ) ];
		}
	}
	return [ 'session' => substr( $id, 0, 8 ), 'stats' => $parsed['stats'], 'sequence' => $seq ];
}

function fmtTokens( int $n ): string {
	if ( $n >= 1_000_000 ) return round( $n / 1_000_000, 1 ) . 'M';
	if ( $n >= 1_000 )     return round( $n / 1_000, 1 ) . 'k';
	return (string) $n;
}

function renderCliffnotes( array $f, bool $c ): void {
	$b = fn( $s ) => bold( $s, $c );
	$d = fn( $s ) => dim( $s, $c );
	$acc = fn( $s ) => $c ? "\033[1;33m{$s}\033[0m" : $s;

	$t = $f['totals'];
	echo "\n" . $b( $f['project']['name'] ) . $d( "  ·  build direction log" ) . "\n";
	echo $d( "{$f['span']['start']} → {$f['span']['end']}  ({$f['span']['days']} days)" ) . "\n\n";

	// Cost / scale readout.
	$model = array_key_first( $f['models'] ) ?: 'unknown';
	$mline = [];
	foreach ( $f['models'] as $m => $n ) {
		if ( $m === '' || $m[0] === '<' ) { continue; } // skip <synthetic> etc.
		$mline[] = "{$m} ×{$n}";
	}
	echo $b( "SCALE\n" );
	printf( "  %-16s %s\n", 'Sessions',   $t['sessions'] );
	printf( "  %-16s %s\n", 'User turns',  $acc( (string) $t['user_turns'] ) . $d( '  ← the direction' ) );
	printf( "  %-16s %s\n", 'Agent tools', number_format( $t['tool_calls'] ) );
	printf( "  %-16s %s\n", 'API calls',   number_format( $t['assistant_messages'] ) );
	printf( "  %-16s %s\n", 'Model',       implode( ', ', $mline ) );
	printf( "  %-16s %s\n", 'Tokens out',  fmtTokens( $f['tokens']['output'] ) . $d( ' generated' ) );
	printf( "  %-16s %s\n", 'Tokens in',   fmtTokens( $f['tokens']['fresh_input'] ) . $d( ' fresh + ' ) . fmtTokens( $f['tokens']['cache_read'] ) . $d( ' cached' ) );
	echo "\n";

	// Steering profile.
	$s = $f['steering'];
	echo $b( "HOW IT WAS STEERED\n" );
	printf( "  %s of %s sessions opened with a saved workflow (slash-command)\n", $acc( (string) $s['slash_sessions'] ), $t['sessions'] );
	printf( "  %s screenshots handed to the agent, %s links referenced\n", $acc( (string) $s['images'] ), $acc( (string) $s['urls'] ) );
	printf( "  %s course-corrections, %s hard interrupts\n", $acc( (string) $s['corrections'] ), $acc( (string) $s['interrupts'] ) );
	echo "\n";

	// The spine.
	echo $b( "THE SPINE " ) . $d( "(first instruction of each session)\n" );
	foreach ( $f['spine'] as $sp ) {
		$isSlash = str_starts_with( $sp['prompt'], '[slash]' );
		$txt     = preg_replace( '/\s+/', ' ', $sp['prompt'] );
		$line    = mb_substr( $txt, 0, 96 );
		echo '  ' . $d( substr( $sp['ts'], 5, 5 ) ) . ' ' . ( $isSlash ? $acc( $line ) : $line ) . "\n";
	}
	echo "\n";

	// Course-corrections - the highest-signal learning material.
	if ( ! empty( $f['corrections'] ) ) {
		echo $b( "COURSE-CORRECTIONS " ) . $d( "(where the human redirected the agent)\n" );
		foreach ( $f['corrections'] as $cor ) {
			$txt = preg_replace( '/\s+/', ' ', $cor['text'] );
			echo '  ' . $d( '↳ ' ) . mb_substr( $txt, 0, 100 ) . "\n";
		}
		echo "\n";
	}

	echo $d( "Full play-by-play:  command-center flow {$f['project']['name']} --full\n" );
	echo $d( "Publishable JSON:   command-center flow {$f['project']['name']} --json\n" );
}

function renderProjectForensic( array $f, bool $full, bool $c ): void {
	// Re-parse each session for the verbatim/interleaved view.
	$acc = fn( $s ) => $c ? "\033[1;33m{$s}\033[0m" : $s;
	$d   = fn( $s ) => dim( $s, $c );
	echo "\n" . bold( $f['project']['name'] . ' - forensic direction log', $c ) . "\n";
	foreach ( FlowExtractor::listProjectSessions( $f['project']['dir'] ) as $s ) {
		$p = FlowExtractor::parseSession( $s['file'] );
		$real = array_filter( $p['turns'], fn( $t ) => $t['role'] === 'user' && $t['kind'] !== 'interrupt' );
		if ( empty( $real ) ) continue;
		echo "\n" . $d( str_repeat( '─', 60 ) ) . "\n";
		echo $d( substr( $s['ts'], 0, 16 ) . '  session ' . substr( $s['id'], 0, 8 ) ) . "\n\n";
		$n = 0;
		foreach ( $p['turns'] as $t ) {
			if ( $t['role'] === 'user' ) {
				if ( $t['kind'] === 'interrupt' ) { echo '  ' . $d( '⛔ interrupted' ) . "\n"; continue; }
				$n++;
				$txt = preg_replace( '/\s+/', ' ', $t['text'] );
				echo '  ' . $acc( $n . '.' ) . ' ' . mb_substr( $txt, 0, $full ? 400 : 200 ) . "\n";
			} elseif ( $full ) {
				$counts = [];
				foreach ( $t['tools'] as [ $name, $label ] ) { $counts[ $name ] = ( $counts[ $name ] ?? 0 ) + 1; }
				$parts = [];
				foreach ( $counts as $k => $v ) { $parts[] = "{$v}×{$k}"; }
				echo '     ' . $d( '↳ ' . implode( ' ', $parts ) ) . "\n";
			}
		}
	}
	echo "\n";
}

function renderSessionFlow( string $id, array $parsed, bool $c ): void {
	$acc = fn( $s ) => $c ? "\033[1;33m{$s}\033[0m" : $s;
	$d   = fn( $s ) => dim( $s, $c );
	$st  = $parsed['stats'];
	echo "\n" . bold( 'session ' . substr( $id, 0, 8 ), $c ) . $d( "  {$st['user_turns']} turns · {$st['tool_calls']} tools · " . fmtTokens( $st['tokens']['output'] ) . ' out' ) . "\n\n";
	$n = 0;
	foreach ( $parsed['turns'] as $t ) {
		if ( $t['role'] === 'user' ) {
			if ( $t['kind'] === 'interrupt' ) { echo '  ' . $d( '⛔ interrupted' ) . "\n"; continue; }
			$n++;
			$txt = preg_replace( '/\s+/', ' ', $t['text'] );
			echo "\n  " . $acc( "USER {$n}" ) . '  ' . mb_substr( $txt, 0, 400 ) . "\n";
		} else {
			$counts = [];
			foreach ( $t['tools'] as [ $name, $label ] ) { $counts[ $name ] = ( $counts[ $name ] ?? 0 ) + 1; }
			$parts = [];
			foreach ( $counts as $k => $v ) { $parts[] = "{$v}×{$k}"; }
			echo '  ' . $d( 'AGENT  ' . implode( ' ', $parts ) ) . "\n";
		}
	}
	echo "\n";
}

// ─── Helpers ─────────────────────────────────────────────────

function resolveProject( ?string $input ): ?string {
	if ( $input === null || $input === '' ) {
		return null;
	}

	// Full path - use directly.
	if ( $input[0] === '/' ) {
		return $input;
	}

	// Basename - look up in known projects.
	$projects = SessionRegistry::listProjects();
	foreach ( $projects as $p ) {
		if ( $p['name'] === $input ) {
			return $p['path'];
		}
	}

	// Partial match.
	foreach ( $projects as $p ) {
		if ( stripos( $p['name'], $input ) !== false ) {
			return $p['path'];
		}
	}

	fwrite( STDERR, "Project not found: {$input}\n" );
	exit( 2 );
}

function resolveAgent( ?string $input ): ?string {
	if ( $input === null || $input === '' ) {
		return null;
	}

	$input = trim( $input );

	// Direct source ID match.
	$providers = SessionRegistry::providers();
	if ( isset( $providers[ $input ] ) ) {
		return $input;
	}

	// Friendly-name mapping (supports hyphenated and non-hyphenated variants).
	$map = [
		'amp'           => 'amp',
		'claude'        => 'claude',
		'claude-code'   => 'claude',
		'claudecode'    => 'claude',
		'commandcode'   => 'commandcode',
		'command-code'  => 'commandcode',
		't3code'        => 't3code',
		't3-code'       => 't3code',
		'opencode'      => 'opencode',
		'open-code'     => 'opencode',
		'kimi'          => 'kimi',
		'antigravity'   => 'antigravity',
		'agy'           => 'antigravity',
		'grok'          => 'grok',
		'grok-code'     => 'grok',
		'grokcode'      => 'grok',
	];

	$key = strtolower( str_replace( [ ' ', '_' ], '-', $input ) );
	if ( isset( $map[ $key ] ) ) {
		return $map[ $key ];
	}

	// Fuzzy: check provider labels.
	foreach ( $providers as $id => $class ) {
		if ( method_exists( $class, 'sourceLabel' ) ) {
			$label = $class::sourceLabel();
			if ( stripos( $label, $input ) !== false ) {
				return $id;
			}
		}
	}

	fwrite( STDERR, "Unknown agent: {$input}\n" );
	fwrite( STDERR, "Available: amp, claude (Claude Code), commandcode (Command Code), t3code (T3 Code), opencode (OpenCode), kimi (Kimi), antigravity (Antigravity), grok (Grok Code)\n" );
	exit( 2 );
}

function formatSnippet( string $snippet, bool $useColor ): string {
	$text = html_entity_decode( $snippet, ENT_QUOTES, 'UTF-8' );

	if ( $useColor ) {
		$text = preg_replace( '/<mark>(.*?)<\/mark>/', "\033[1;33m$1\033[0m", $text );
	}

	$text = strip_tags( $text );
	$text = preg_replace( '/\s+/', ' ', $text );
	return trim( $text );
}

function stripSnippetHtml( string $snippet ): string {
	$text = html_entity_decode( $snippet, ENT_QUOTES, 'UTF-8' );
	$text = strip_tags( $text );
	$text = preg_replace( '/\s+/', ' ', $text );
	return trim( $text );
}

function detectColor( array $flags ): bool {
	if ( ! empty( $flags['no-color'] ) ) {
		return false;
	}
	if ( getenv( 'NO_COLOR' ) !== false ) {
		return false;
	}
	if ( ! function_exists( 'posix_isatty' ) || ! posix_isatty( STDOUT ) ) {
		return false;
	}
	$term = getenv( 'TERM' );
	if ( $term === 'dumb' ) {
		return false;
	}
	return true;
}

function bold( string $text, bool $useColor ): string {
	return $useColor ? "\033[1m{$text}\033[0m" : $text;
}

function dim( string $text, bool $useColor ): string {
	return $useColor ? "\033[2m{$text}\033[0m" : $text;
}

